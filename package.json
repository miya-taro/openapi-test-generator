{
  "name": "openapi-test-gen",
  "version": "0.1.0",
  "description": "OpenAPI 3.x からインターフェース観点テスト仕様 JSON を自動生成するジェネレータ",
  "type": "module",
  "bin": {
    "openapi-test-gen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^15.0.0",
    "exceljs": "^4.4.0",
    "pino": "^10.3.1",
    "randexp": "^0.5.3"
  }
}
